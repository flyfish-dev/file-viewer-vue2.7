  "author": {
    "name": "Wangyu",
    "email": "wybaby168@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flyfish-dev/file-viewer-vue2.7.git"
  },
  "homepage": "https://github.com/flyfish-dev/file-viewer-vue2.7",
  "bugs": {
    "url": "https://github.com/flyfish-dev/file-viewer-vue2.7/issues"
  },
